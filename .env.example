# Fully offline and deterministic by default.
HAUNTED_STUDIO_PROVIDER=deterministic

# Optional live OpenAI provider. Keep real values outside version control.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional runtime locations and local mailbox settings.
HAUNTED_STUDIO_HOME=.haunted-studio
HAUNTED_STUDIO_HOST=127.0.0.1
HAUNTED_STUDIO_PORT=19820

# Studio art-loop interface (npm run studio). The Setup panel in the UI can take
# the image API key in-memory and pick the model, so these are optional. Load
# this file with: node --env-file=.env src/cli.js studio
# HAUNTED_STUDIO_ARTIFACT=image          # mock (default) or image
# HAUNTED_STUDIO_IMAGE_API_KEY=          # never commit a real key (.env is gitignored)
# HAUNTED_STUDIO_IMAGE_MODEL=gpt-image-1
# HAUNTED_STUDIO_IMAGE_BASE_URL=https://api.openai.com/v1
# HAUNTED_STUDIO_IMAGE_SIZE=1024x1024
